{
  "name": "lingshu-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "灵枢 / Lingshu runtime-first desktop agent platform.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
