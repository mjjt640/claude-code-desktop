    "dev:desktop": "pnpm --filter @lingshu/desktop dev"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
